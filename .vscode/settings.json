{
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "typescript": true
  },
  "go.buildTags": "playwright,buildables",
  "go.toolsEnvVars": {
    "GOEXPERIMENT": "jsonv2"
  },
  "go.testEnvVars": {
    "GOEXPERIMENT": "jsonv2"
  },
  "gopls": {
    "ui.diagnostic.analyses": {
      "stdversion": false
    }
  },
  "prettier.documentSelectors": ["**/*.svelte"],
  "tasks.statusbar.default.hide": true,
  "tasks.statusbar.limit": 8,
  "github.copilot.chat.summarizeAgentConversationHistory.enabled": false,
  "snyk.advanced.autoSelectOrganization": false,
  "js/ts.tsdk.path": "node_modules/@typescript/native-preview"
}
