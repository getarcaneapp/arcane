# syntax=docker/dockerfile:1
ARG VERSION="dev"
ARG REVISION="unknown"

FROM --platform=$BUILDPLATFORM golang:1.26-trixie AS agent-builder
ARG TARGETARCH
ARG TARGETVARIANT
ARG BUILD_TAGS="exclude_frontend"
ARG VERSION="dev"
ARG REVISION="unknown"
ARG BUILD_TIME="unknown"
WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates tzdata curl jq \
&& apt-get clean && rm -rf /var/lib/apt/lists/*

COPY go.work ./
COPY types ./types
COPY cli ./cli
COPY backend/go.mod backend/go.sum ./backend/
WORKDIR /build/backend
RUN --mount=type=cache,target=/go/pkg/mod go mod download

COPY backend ./
COPY .arcane.json ../arcane.json

RUN --mount=type=cache,target=/root/.cache/go-build \
    if [ "${VERSION}" = "dev" ]; then VERSION=$(jq -r '.version // "dev"' ../arcane.json); fi && \
    if [ "${REVISION}" = "unknown" ]; then REVISION=$(jq -r '.revision // "unknown"' ../arcane.json); fi && \
    if [ "${BUILD_TIME}" = "unknown" ]; then BUILD_TIME=$(jq -r '.buildTime // "unknown"' ../arcane.json); fi && \
    export GOARCH="${TARGETARCH}" && \
    if [ "${TARGETARCH}" = "arm" ]; then \
        GOARM="${TARGETVARIANT#v}"; \
        if [ -z "${GOARM}" ]; then GOARM="7"; fi; \
        export GOARM; \
    fi && \
    CGO_ENABLED=0 GOOS=linux \
    go build \
    -tags "${BUILD_TAGS}" \
    -ldflags "-w -s -X github.com/getarcaneapp/arcane/backend/internal/config.Version=${VERSION} -X github.com/getarcaneapp/arcane/backend/internal/config.Revision=${REVISION} -X github.com/getarcaneapp/arcane/backend/internal/config.BuildTime=${BUILD_TIME}" \
    -trimpath \
    -o /out/arcane-agent \
    ./cmd/main.go

FROM --platform=linux/amd64 debian:trixie-slim AS intel-gpu-top-builder
ARG TARGETARCH
WORKDIR /src

RUN if [ "${TARGETARCH}" != "amd64" ]; then \
        mkdir -p /out; \
        exit 0; \
    fi && \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates git python3 meson ninja-build pkg-config \
    bison flex gcc g++ make libc6-dev \
    libdrm-dev libpciaccess-dev libkmod-dev libproc2-dev libdw-dev \
    libpixman-1-dev libcairo2-dev libpci-dev libudev-dev libglib2.0-dev \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN if [ "${TARGETARCH}" != "amd64" ]; then \
        exit 0; \
    fi && \
    git clone --branch "v2.4" --depth 1 \
    https://gitlab.freedesktop.org/drm/igt-gpu-tools.git /src/igt-gpu-tools

WORKDIR /src/igt-gpu-tools

RUN if [ "${TARGETARCH}" != "amd64" ]; then \
        mkdir -p /out; \
        exit 0; \
    fi && \
    meson setup build \
    -Ddocs=disabled \
    -Dman=disabled \
    -Dtestplan=disabled \
    -Dtests=disabled \
    -Dchamelium=disabled \
    -Doverlay=disabled \
    -Drunner=disabled \
    -Dxe_driver=disabled \
    -Dxe_eudebug=disabled \
    -Dvalgrind=disabled \
    -Dlibunwind=disabled \
    -Dvmtb=disabled \
    -Dlibdrm_drivers=intel && \
    ninja -C build tools/intel_gpu_top && \
    install -Dm755 build/tools/intel_gpu_top /out/usr/local/bin/intel_gpu_top && \
    ldd build/tools/intel_gpu_top | awk '($2 == "=>" && $3 ~ /^\\//) || ($1 ~ /^\\//) { print ($3 ~ /^\\// ? $3 : $1) }' | sort -u | while read -r lib; do \
        [ -f "${lib}" ] || continue; \
        case "$(basename "${lib}")" in \
            libc.so.6|ld-linux-*.so.*) continue ;; \
        esac; \
        install -Dm755 "${lib}" "/out/usr/local/lib/intel_gpu_top/$(basename "${lib}")"; \
    done

FROM debian:trixie-slim AS runtime-deps

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates tzdata \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

FROM debian:trixie-slim AS agent
ARG TARGETARCH

WORKDIR /app
RUN mkdir -p /app/data

COPY --from=runtime-deps /etc/ca-certificates.conf /etc/ca-certificates.conf
COPY --from=runtime-deps /etc/localtime /etc/localtime
COPY --from=runtime-deps /etc/ssl/certs /etc/ssl/certs
COPY --from=runtime-deps /usr/share/ca-certificates /usr/share/ca-certificates
COPY --from=runtime-deps /usr/share/zoneinfo /usr/share/zoneinfo
COPY --from=intel-gpu-top-builder /out/ /
COPY --from=agent-builder /out/arcane-agent ./arcane-agent

ARG VERSION="dev"
ARG REVISION="unknown"

ENV NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility \
    ROCR_VISIBLE_DEVICES=all \
    HIP_VISIBLE_DEVICES=all \
    ONEAPI_DEVICE_SELECTOR=level_zero:*,opencl:* \
    LD_LIBRARY_PATH=/usr/local/lib/intel_gpu_top:/usr/local/nvidia/lib:/usr/local/nvidia/lib64:/opt/rocm/lib:/opt/intel/oneapi/lib:/opt/intel/oneapi/lib/intel64:/usr/lib/x86_64-linux-gnu:/usr/lib/aarch64-linux-gnu:/usr/lib64:/usr/lib:/lib64:/lib

ENV ENVIRONMENT=production \
    AGENT_MODE=true \
    GIN_MODE=release \
    PORT=3553

EXPOSE 3553
VOLUME ["/app/data"]

LABEL com.getarcaneapp.arcane.agent="true"

CMD ["./arcane-agent"]
