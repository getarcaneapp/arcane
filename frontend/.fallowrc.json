{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/routes/**/*.{svelte,ts,js}",
    "src/hooks.*.ts",
    "src/lib/paraglide/messages/_index.js",
    "src/lib/index.ts",
    "src/lib/components/**/index.ts"
  ],
  "ignorePatterns": [
    "src/lib/paraglide/server.js",
    "src/lib/paraglide/runtime.js",
    "src/lib/paraglide/registry.js",
    "email-templates/**",
    "tests/**"
  ],
  "ignoreDependencies": [
    "@iconify/json",
    "@tanstack/svelte-query-devtools",
    "paneforge",
    "shadcn-svelte",
    "svelte-toolbelt",
    "isomorphic-dompurify",
    "tailwindcss",
    "tw-animate-css"
  ],
  "ignoreExports": [
    {
      "file": "src/lib/components/code-editor/analysis/compose-analysis.ts",
      "exports": ["findYamlPositionContext", "analyzeComposeContent", "resolveVariableSourceAtPosition"]
    },
    {
      "file": "src/lib/components/code-editor/analysis/compose-schema.ts",
      "exports": ["getComposeSchemaContext", "getCompletionOptionsForPath", "getEnumValueCompletions", "getSchemaDocForPath"]
    }
  ],
  "ignoreExportsUsedInFile": {
    "type": true,
    "interface": true
  },
  "unusedComponentProps": {
    "ignorePattern": "^_"
  }
}
