{
  "name": "arcane-frontend",
  "private": true,
  "version": "2.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000 --host",
    "build": "vite build",
    "preview": "vite preview --port 3000",
    "check": "pnpm paraglide:compile && svelte-kit sync && svelte-check-rs --tsconfig ./tsconfig.json",
    "format": "oxfmt ./src",
    "format:check": "oxfmt --check ./src",
    "check:watch": "pnpm paraglide:compile && svelte-kit sync && svelte-check-rs --tsconfig ./tsconfig.json --watch",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy cookie preferredLanguage baseLocale --silent",
    "fallow": "fallow"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.6",
    "@fontsource-variable/geist-mono": "^5.3.0",
    "@fontsource-variable/montserrat": "^5.3.0",
    "@internationalized/date": "^3.12.2",
    "@lezer/highlight": "^1.2.3",
    "@sveltejs/kit": "^3.0.0-next.8",
    "@tanstack/svelte-query": "^6.1.37",
    "@tanstack/svelte-table": "^9.0.0-beta.47",
    "@tanstack/table-core": "9.0.0-beta.47",
    "@tanstack/virtual-core": "^3.17.4",
    "@uiw/codemirror-themes": "^4.25.11",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/svelte": "^1.6.2",
    "ajv": "^8.20.0",
    "ansi-to-html": "^0.7.2",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-svelte": "^8.6.0",
    "formsnap": "^2.0.1",
    "ky": "^2.0.2",
    "marked": "^18.0.6",
    "mode-watcher": "^1.1.0",
    "runed": "^0.37.1",
    "svelte": "^5.56.7",
    "svelte-codemirror-editor": "^2.1.0",
    "svelte-easy-crop": "^5.0.1",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "vaul-svelte": "1.0.0-next.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.499",
    "@inlang/paraglide-js": "2.22.0",
    "@sveltejs/adapter-static": "^4.0.0-next.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/svelte-query-devtools": "^6.1.36",
    "@types/node": "^26.1.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "fallow": "^3.4.2",
    "isomorphic-dompurify": "^3.19.0",
    "oxfmt": "^0.58.0",
    "paneforge": "^1.0.2",
    "shadcn-svelte": "^1.4.1",
    "svelte-check-rs": "^0.11.0",
    "svelte-toolbelt": "^0.10.6",
    "sveltekit-superforms": "^2.30.2",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.1.5"
  }
}
