{
  "name": "arcane-repo",
  "private": true,
  "packageManager": "pnpm@11.0.6+sha512.97f906e1da2bedac3df83cadae04b4753a130092dd49d55cd36825ad3e623e9df3f97754f8f259e699172a360fac569acf2f908e7732bdae3eddb2dcf7e121fd",
  "engines": {
    "node": ">=25"
  },
  "workspaces": [
    "frontend",
    "tests",
    "email-templates"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*": [
      "sh -c 'just format frontend --check'"
    ],
    "{tests,email-templates}/**/*.{ts,tsx,js,jsx,mts,cts}": [
      "sh -c 'just format js --check'"
    ],
    "{backend,cli,types}/**/*": [
      "sh -c 'just format go --check'"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
