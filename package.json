{
  "name": "arcane-repo",
  "private": true,
  "packageManager": "pnpm@11.16.0+sha512.b767e9a98fc87aec0f42daefcd0e84941c2cdb45d73c4e1e68860fb2bdfdbe032ab592105479e5e05c237f740c8a5ffdbbb52385797ddc2296745a1bbb883e8d",
  "engines": {
    "node": ">=26"
  },
  "workspaces": [
    "frontend",
    "tests",
    "email-templates"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky"
  },
  "lint-staged": {
    "frontend/**/*": [
      "sh -c 'just format frontend --check'"
    ],
    "{tests,email-templates}/**/*.{ts,tsx,js,jsx,mts,cts}": [
      "sh -c 'just format js --check'"
    ],
    "{backend,cli,types}/**/*": [
      "sh -c 'just format go --check'"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
